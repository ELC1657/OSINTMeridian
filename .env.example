# Meridian API Keys — copy this file to ~/.config/meridian/.env and fill in your keys

# Shodan — https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# GitHub — https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=

# Hunter.io — https://hunter.io/users/sign_up
HUNTER_API_KEY=

# Apollo.io — https://apollo.io (free tier)
APOLLO_API_KEY=

# IntelligenceX — https://intelx.io (free tier, 10 searches/mo)
INTELX_API_KEY=

# RapidAPI (BreachDirectory) — https://rapidapi.com (free tier, 50 req/mo)
RAPIDAPI_KEY=

# Dehashed — https://dehashed.com (paid)
DEHASHED_EMAIL=
DEHASHED_API_KEY=

# SecurityTrails — https://securitytrails.com (free tier, 50 queries/mo)
SECTRAILS_API_KEY=

# NVD / NIST — https://nvd.nist.gov/developers/request-an-api-key (free)
# Optional — raises CVE query rate limit from 5/30s to 50/30s
NVD_API_KEY=
